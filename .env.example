# Server
PORT=4000
HOST=0.0.0.0
PUBLIC_BASE_URL=http://YOUR_SERVER_IP:4000

# MongoDB (use host reachable from Docker, e.g. host IP or mongo service name)
MONGODB_URI=mongodb://127.0.0.1:27017/your_db_name

# Auth
JWT_SECRET=change_me

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SMTP (OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional
PING_NAME=
PING_AGE=
SHOP_CATEGORIES_PRIMARY_IDS=
